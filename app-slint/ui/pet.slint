import { Theme } from "common.slint";

export component PetWindow inherits Window {
    in property <image> sheet;
    in property <int> frame-col;
    in property <int> frame-row;
    in property <float> pet-scale: 1.0;
    callback pet-clicked;
    callback drag-start;

    no-frame: true;
    always-on-top: true;
    background: transparent;
    width: 192px * pet-scale;
    height: 208px * pet-scale;
    title: "PetPhrase";

    img := Image {
        width: parent.width;
        height: parent.height;
        source: root.sheet;
        image-fit: fill;
        source-clip-x: root.frame-col * 192;
        source-clip-y: root.frame-row * 208;
        source-clip-width: 192;
        source-clip-height: 208;
    }

    // 拖拽后吞掉本次 click:系统拖窗接管后松手仍会触发 clicked
    property <bool> dragged: false;

    ta := TouchArea {
        mouse-cursor: pointer;
        moved => {
            if (self.pressed && (Math.abs(self.mouse-x / 1px - self.pressed-x / 1px) > 4 || Math.abs(self.mouse-y / 1px - self.pressed-y / 1px) > 4)) {
                root.dragged = true;
                root.drag-start();
            }
        }
        clicked => {
            if (root.dragged) {
                root.dragged = false;
            } else {
                root.pet-clicked();
            }
        }
    }
}
