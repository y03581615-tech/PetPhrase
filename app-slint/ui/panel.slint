import { Theme, PanelItemUi, TabUi, GroupIcon, IconButton } from "common.slint";

export component PanelWindow inherits Window {
    in property <[TabUi]> tabs;
    in property <[PanelItemUi]> items;
    in property <float> content-h;
    in property <bool> show-grid-btn;
    in-out property <string> search-text;
    // 复制反馈:命中条目下标,-1 无
    in property <int> copied-idx: -1;
    in property <int> failed-idx: -1;

    callback tab-clicked(int);
    callback item-clicked(int);
    callback gear-clicked;
    callback search-changed(string);
    callback item-hovered(int, float);
    callback item-unhovered;
    callback escape-pressed;

    no-frame: true;
    always-on-top: true;
    background: transparent;
    width: 300px;
    height: 400px;
    title: "常用语";
    icon: @image-url("icon.png");
    default-font-family: "Microsoft YaHei UI";
    default-font-size: 13px;

    in-out property <bool> grid-open: false;

    forward-focus: search-input;

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (root.grid-open) {
                    root.grid-open = false;
                } else {
                    root.escape-pressed();
                }
                return accept;
            }
            reject
        }

        Rectangle {
            border-radius: 14px;
            background: Theme.surface-panel;
            border-width: 1px;
            border-color: Theme.border-soft;
            clip: true;

            VerticalLayout {
                padding: 0;
                spacing: 0;

                // ---- 顶部:搜索 + 齿轮 ----
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 10px;
                    padding-bottom: 6px;
                    spacing: 8px;

                    Rectangle {
                        border-radius: 10px;
                        background: Theme.surface-input;
                        border-width: 1px;
                        border-color: Theme.border-soft;
                        height: 30px;
                        horizontal-stretch: 1;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("icons/search.svg");
                                    colorize: Theme.text-placeholder;
                                    width: 14px;
                                    height: 14px;
                                }
                            }
                            Rectangle {
                                clip: true;
                                search-input := TextInput {
                                    text <=> root.search-text;
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    single-line: true;
                                    changed text => { root.search-changed(self.text); }
                                }
                                if search-input.text == "": Text {
                                    text: "搜索常用语…";
                                    color: Theme.text-placeholder;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    IconButton {
                        icon: @image-url("icons/settings.svg");
                        clicked => { root.gear-clicked(); }
                    }
                }

                // ---- 分组 Tab 条 ----
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-bottom: 8px;
                    spacing: 6px;

                    tab-strip := Flickable {
                        height: 28px;
                        horizontal-stretch: 1;
                        viewport-height: 28px;
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            for tab[i] in root.tabs: Rectangle {
                                border-radius: 999px;
                                background: tab.active ? Theme.surface-tab-active : (tab-ta.has-hover ? Theme.surface-item-hover : Theme.surface-tab);
                                height: 26px;
                                width: tab-label.preferred-width + 24px;
                                animate background { duration: 150ms; }
                                tab-label := Text {
                                    text: tab.name;
                                    color: tab.active ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 12px;
                                    font-weight: tab.active ? 600 : 400;
                                }
                                tab-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.tab-clicked(i); }
                                }
                            }
                        }
                    }

                    if root.show-grid-btn: IconButton {
                        icon: @image-url("icons/layout-grid.svg");
                        clicked => { root.grid-open = !root.grid-open; }
                    }
                }

                // ---- 混排列表 ----
                Flickable {
                    vertical-stretch: 1;
                    viewport-height: root.content-h * 1px + 20px;

                    Rectangle {
                        x: 10px;
                        y: 0;
                        width: parent.width - 20px;

                        for item[i] in root.items: Rectangle {
                            x: item.x * 1px;
                            y: item.y * 1px;
                            width: item.w * 1px;
                            height: item.h * 1px;
                            border-radius: item.is-chip ? 999px : 10px;
                            background: i == root.copied-idx ? Theme.accent-soft : (item-ta.has-hover ? Theme.surface-item-hover : Theme.surface-item);
                            border-width: 1px;
                            border-color: i == root.copied-idx ? Theme.accent
                                : i == root.failed-idx ? Theme.danger
                                : item-ta.has-hover ? Theme.accent : Theme.border-soft;
                            animate background { duration: 150ms; }

                            VerticalLayout {
                                padding-left: item.is-chip ? 12px : 10px;
                                padding-right: item.is-chip ? 12px : 10px;
                                padding-top: item.is-chip ? 0 : 8px;
                                padding-bottom: item.is-chip ? 0 : 8px;
                                alignment: item.is-chip ? center : start;
                                spacing: 2px;
                                Text {
                                    text: item.text;
                                    color: Theme.text-primary;
                                    font-size: 12.5px;
                                    wrap: item.is-chip ? no-wrap : word-wrap;
                                    overflow: elide;
                                    vertical-stretch: 1;
                                }
                                if item.badge != "": Text {
                                    text: item.badge;
                                    color: Theme.text-muted;
                                    font-size: 10.5px;
                                }
                            }

                            if i == root.copied-idx: Image {
                                source: @image-url("icons/check.svg");
                                colorize: Theme.success;
                                width: 14px;
                                height: 14px;
                                x: parent.width - 22px;
                                y: (parent.height - 14px) / 2;
                            }

                            item-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.item-clicked(i); }
                                changed has-hover => {
                                    if (self.has-hover && item.truncated) {
                                        root.item-hovered(i, item.y);
                                    } else if (!self.has-hover) {
                                        root.item-unhovered();
                                    }
                                }
                            }
                        }

                        if root.items.length == 0: Text {
                            y: 40px;
                            width: parent.width;
                            horizontal-alignment: center;
                            text: root.search-text == "" ? "这个分组还没有常用语\n点右上角 ⚙ 去添加" : "没有匹配的常用语";
                            color: Theme.text-muted;
                            font-size: 12px;
                        }
                    }
                }
            }
        }

        // ---- 全组宫格覆层 ----
        if root.grid-open: Rectangle {
            x: 12px;
            y: 78px;
            width: parent.width - 24px;
            background: Theme.surface-sheet;
            border-width: 1px;
            border-color: Theme.border-soft;
            border-radius: 10px;
            drop-shadow-blur: 24px;
            drop-shadow-color: #0f172a2e;
            height: Math.min(280px, grid-inner.preferred-height + 20px);
            clip: true;

            Flickable {
                x: 10px;
                y: 10px;
                width: parent.width - 20px;
                height: parent.height - 20px;
                grid-inner := VerticalLayout {
                    spacing: 8px;
                    for rowidx in Math.ceil(root.tabs.length / 3): HorizontalLayout {
                        spacing: 8px;
                        for colidx in 3: Rectangle {
                            property <int> flat: rowidx * 3 + colidx;
                            property <bool> valid: flat < root.tabs.length;
                            horizontal-stretch: 1;
                            height: 56px;
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: valid && root.tabs[flat].active ? Theme.accent : (valid ? Theme.border-soft : transparent);
                            background: !valid ? transparent
                                : root.tabs[flat].active ? Theme.accent-soft
                                : cell-ta.has-hover ? Theme.surface-item-hover : Theme.surface-item;
                            if valid: VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                HorizontalLayout {
                                    alignment: center;
                                    GroupIcon { idx: root.tabs[flat].icon-idx; }
                                }
                                Text {
                                    text: root.tabs[flat].name;
                                    horizontal-alignment: center;
                                    font-size: 11.5px;
                                    color: root.tabs[flat].active ? Theme.text-primary : Theme.text-secondary;
                                    overflow: elide;
                                }
                            }
                            cell-ta := TouchArea {
                                enabled: valid;
                                mouse-cursor: pointer;
                                clicked => {
                                    root.grid-open = false;
                                    root.tab-clicked(flat);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
