import { Theme, PanelItemUi, TabUi, GroupIcon, IconButton, InputArea, GhostButton, PrimaryButton } from "common.slint";

/// 右键菜单行:图标 + 文字,悬停高亮,样式随主题 token
component CtxMenuRow inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> danger: false;
    callback clicked;
    height: 32px;
    border-radius: 7px;
    background: row-ta.has-hover ? (danger ? #fee2e2 : Theme.surface-item-hover) : transparent;
    animate background { duration: 150ms; }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;
        VerticalLayout {
            alignment: center;
            Image {
                source: root.icon;
                colorize: root.danger ? Theme.danger : Theme.text-secondary;
                width: 14px;
                height: 14px;
            }
        }
        Text {
            text: root.label;
            font-size: 12.5px;
            color: root.danger ? Theme.danger : Theme.text-primary;
            vertical-alignment: center;
        }
    }
    row-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component PanelWindow inherits Window {
    in property <[TabUi]> tabs;
    in property <[PanelItemUi]> items;
    in property <float> content-h;
    in property <bool> show-grid-btn;
    in-out property <string> search-text;
    // 复制反馈:命中条目下标,-1 无
    in property <int> copied-idx: -1;
    in property <int> failed-idx: -1;

    callback tab-clicked(int);
    callback item-clicked(int);
    callback gear-clicked;
    callback search-changed(string);
    callback escape-pressed;
    // 常驻开关(会话级,不持久化)
    in-out property <bool> pinned: false;
    // 右键菜单动作,参数 = 条目下标(-1 = 空白区域)
    callback item-edit-requested(int);
    callback item-delete-requested(int);
    callback item-add-requested(int);

    // 右键菜单状态;ctx-idx = -1 表示空白区域(只给添加)
    in-out property <bool> ctx-open: false;
    property <int> ctx-idx: -1;
    property <length> ctx-x;
    property <length> ctx-y;

    // 就地编辑器(编辑/新增共用);文本由 Rust 打开时灌入
    in-out property <bool> editor-open: false;
    in property <string> editor-text;
    in property <bool> editor-is-add;
    callback editor-saved(string);

    // 保存失败横幅文本(Rust 灌入,空 = 无错误;保存成功自动清,点横幅手动关)
    in-out property <string> save-error;

    no-frame: true;
    always-on-top: true;
    background: transparent;
    width: 300px;
    height: 400px;
    title: "常用语";
    icon: @image-url("icon.png");
    default-font-family: "Microsoft YaHei UI";
    default-font-size: 13px;

    in-out property <bool> grid-open: false;

    forward-focus: search-input;

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (root.editor-open) {
                    root.editor-open = false;
                } else if (root.ctx-open) {
                    root.ctx-open = false;
                } else if (root.grid-open) {
                    root.grid-open = false;
                } else {
                    root.escape-pressed();
                }
                return accept;
            }
            reject
        }

        Rectangle {
            border-radius: 14px;
            background: Theme.surface-panel;
            border-width: 1px;
            border-color: Theme.border-soft;
            clip: true;

            VerticalLayout {
                padding: 0;
                spacing: 0;

                // ---- 顶部:搜索 + 齿轮 ----
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 10px;
                    padding-bottom: 6px;
                    spacing: 8px;

                    Rectangle {
                        border-radius: 10px;
                        background: Theme.surface-input;
                        border-width: 1px;
                        border-color: Theme.border-soft;
                        height: 30px;
                        horizontal-stretch: 1;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("icons/search.svg");
                                    colorize: Theme.text-placeholder;
                                    width: 14px;
                                    height: 14px;
                                }
                            }
                            Rectangle {
                                clip: true;
                                search-input := TextInput {
                                    text <=> root.search-text;
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    single-line: true;
                                    changed text => { root.search-changed(self.text); }
                                }
                                if search-input.text == "": Text {
                                    text: "搜索常用语…";
                                    color: Theme.text-placeholder;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    IconButton {
                        icon: @image-url("icons/pin.svg");
                        active: root.pinned;
                        clicked => { root.pinned = !root.pinned; }
                    }
                    IconButton {
                        icon: @image-url("icons/settings.svg");
                        clicked => { root.gear-clicked(); }
                    }
                }

                // ---- 分组 Tab 条 ----
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-bottom: 8px;
                    spacing: 6px;

                    tab-strip := Flickable {
                        height: 28px;
                        horizontal-stretch: 1;
                        viewport-height: 28px;
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            for tab[i] in root.tabs: Rectangle {
                                border-radius: 999px;
                                background: tab.active ? Theme.surface-tab-active : (tab-ta.has-hover ? Theme.surface-item-hover : Theme.surface-tab);
                                height: 26px;
                                width: tab-label.preferred-width + 24px;
                                animate background { duration: 150ms; }
                                tab-label := Text {
                                    text: tab.name;
                                    color: tab.active ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 12px;
                                    font-weight: tab.active ? 600 : 400;
                                }
                                tab-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.tab-clicked(i); }
                                }
                            }
                        }
                    }

                    if root.show-grid-btn: IconButton {
                        icon: @image-url("icons/layout-grid.svg");
                        clicked => { root.grid-open = !root.grid-open; }
                    }
                }

                // ---- 混排列表 ----
                list-flick := Flickable {
                    vertical-stretch: 1;
                    viewport-height: Math.max(root.content-h * 1px + 20px, self.height);

                    Rectangle {
                        x: 10px;
                        y: 0;
                        width: parent.width - 20px;
                        height: list-flick.viewport-height;

                        // 空白区右键 → 只带「添加」的菜单(在条目之下,不抢条目事件)
                        TouchArea {
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                    root.ctx-idx = -1;
                                    root.ctx-x = self.absolute-position.x + self.mouse-x;
                                    root.ctx-y = self.absolute-position.y + self.mouse-y;
                                    root.ctx-open = true;
                                }
                            }
                        }

                        for item[i] in root.items: Rectangle {
                            x: item.x * 1px;
                            y: item.y * 1px;
                            width: item.w * 1px;
                            height: item.h * 1px;
                            border-radius: item.is-chip ? 999px : 10px;
                            background: i == root.copied-idx ? Theme.accent-soft : (item-ta.has-hover ? Theme.surface-item-hover : Theme.surface-item);
                            border-width: 1px;
                            border-color: i == root.copied-idx ? Theme.accent
                                : i == root.failed-idx ? Theme.danger
                                : item-ta.has-hover ? Theme.accent : Theme.border-soft;
                            animate background { duration: 150ms; }
                            // 文本显式定高 + clip:多行/超长原文的实际渲染高度可超 Rust 估算,
                            // 交给 layout 协商会按全文最小高度溢出压到下一条,必须硬约束
                            clip: true;

                            if item.is-chip: Text {
                                width: parent.width;
                                height: parent.height;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                text: item.text;
                                color: Theme.text-primary;
                                font-size: 12.5px;
                                overflow: elide;
                            }
                            if !item.is-chip: Text {
                                x: 10px;
                                y: 10px;
                                width: parent.width - 20px;
                                height: parent.height - 20px - (item.badge == "" ? 0px : 16px);
                                text: item.text;
                                color: Theme.text-primary;
                                font-size: 12.5px;
                                wrap: word-wrap;
                                overflow: elide;
                            }
                            if item.badge != "" && !item.is-chip: Text {
                                x: 10px;
                                y: parent.height - 24px;
                                text: item.badge;
                                color: Theme.text-muted;
                                font-size: 10.5px;
                            }

                            if i == root.copied-idx: Image {
                                source: @image-url("icons/check.svg");
                                colorize: Theme.success;
                                width: 14px;
                                height: 14px;
                                x: parent.width - 22px;
                                y: (parent.height - 14px) / 2;
                            }

                            item-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.item-clicked(i); }
                                pointer-event(event) => {
                                    if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                        root.ctx-idx = i;
                                        root.ctx-x = self.absolute-position.x + self.mouse-x;
                                        root.ctx-y = self.absolute-position.y + self.mouse-y;
                                        root.ctx-open = true;
                                    }
                                }
                            }
                        }

                        if root.items.length == 0: Text {
                            y: 40px;
                            width: parent.width;
                            horizontal-alignment: center;
                            text: root.search-text == "" ? "这个分组还没有常用语\n点右上角 ⚙ 去添加" : "没有匹配的常用语";
                            color: Theme.text-muted;
                            font-size: 12px;
                        }
                    }
                }
            }
        }

        // ---- 全组宫格覆层 ----
        if root.grid-open: Rectangle {
            x: 12px;
            y: 78px;
            width: parent.width - 24px;
            background: Theme.surface-sheet;
            border-width: 1px;
            border-color: Theme.border-soft;
            border-radius: 10px;
            drop-shadow-blur: 24px;
            drop-shadow-color: #0f172a2e;
            height: Math.min(280px, grid-inner.preferred-height + 20px);
            clip: true;

            Flickable {
                x: 10px;
                y: 10px;
                width: parent.width - 20px;
                height: parent.height - 20px;
                grid-inner := VerticalLayout {
                    spacing: 8px;
                    for rowidx in Math.ceil(root.tabs.length / 3): HorizontalLayout {
                        spacing: 8px;
                        for colidx in 3: Rectangle {
                            property <int> flat: rowidx * 3 + colidx;
                            property <bool> valid: flat < root.tabs.length;
                            horizontal-stretch: 1;
                            height: 56px;
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: valid && root.tabs[flat].active ? Theme.accent : (valid ? Theme.border-soft : transparent);
                            background: !valid ? transparent
                                : root.tabs[flat].active ? Theme.accent-soft
                                : cell-ta.has-hover ? Theme.surface-item-hover : Theme.surface-item;
                            if valid: VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                HorizontalLayout {
                                    alignment: center;
                                    GroupIcon { idx: root.tabs[flat].icon-idx; }
                                }
                                Text {
                                    text: root.tabs[flat].name;
                                    horizontal-alignment: center;
                                    font-size: 11.5px;
                                    color: root.tabs[flat].active ? Theme.text-primary : Theme.text-secondary;
                                    overflow: elide;
                                }
                            }
                            cell-ta := TouchArea {
                                enabled: valid;
                                mouse-cursor: pointer;
                                clicked => {
                                    root.grid-open = false;
                                    root.tab-clicked(flat);
                                }
                            }
                        }
                    }
                }
            }
        }

        // ---- 右键菜单(面板内浮层,勿用独立窗口——焦点链会触发失焦自隐) ----
        if root.ctx-open: Rectangle {
            // 全屏点击拦截:点菜单外任意处关闭
            TouchArea {
                clicked => { root.ctx-open = false; }
                pointer-event(event) => {
                    if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                        root.ctx-open = false;
                    }
                }
            }
            Rectangle {
                x: Math.min(root.ctx-x, root.width - self.width - 8px);
                y: Math.min(root.ctx-y, root.height - self.height - 8px);
                width: 148px;
                height: menu-col.preferred-height + 12px;
                background: Theme.surface-sheet;
                border-width: 1px;
                border-color: Theme.border-soft;
                border-radius: 10px;
                drop-shadow-blur: 24px;
                drop-shadow-color: #0f172a2e;
                // 挡住穿透到下层的点击
                TouchArea { }
                menu-col := VerticalLayout {
                    x: 6px;
                    y: 6px;
                    width: parent.width - 12px;
                    spacing: 2px;
                    if root.ctx-idx >= 0: CtxMenuRow {
                        icon: @image-url("icons/pencil.svg");
                        label: "编辑此条";
                        clicked => {
                            root.ctx-open = false;
                            root.item-edit-requested(root.ctx-idx);
                        }
                    }
                    CtxMenuRow {
                        icon: @image-url("icons/plus.svg");
                        label: "添加常用语";
                        clicked => {
                            root.ctx-open = false;
                            root.item-add-requested(root.ctx-idx);
                        }
                    }
                    if root.ctx-idx >= 0: CtxMenuRow {
                        icon: @image-url("icons/trash-2.svg");
                        label: "删除此条";
                        danger: true;
                        clicked => {
                            root.ctx-open = false;
                            root.item-delete-requested(root.ctx-idx);
                        }
                    }
                }
            }
        }

        // ---- 就地编辑器(编辑/新增共用,面板内浮层) ----
        if root.editor-open: Rectangle {
            background: #0f172a40;
            TouchArea { clicked => { root.editor-open = false; } }
            Rectangle {
                x: 14px;
                y: 70px;
                width: parent.width - 28px;
                height: 230px;
                background: Theme.surface-sheet;
                border-width: 1px;
                border-color: Theme.border-soft;
                border-radius: 12px;
                drop-shadow-blur: 24px;
                drop-shadow-color: #0f172a2e;
                TouchArea { } // 挡穿透
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: root.editor-is-add ? "添加常用语" : "编辑常用语";
                        font-size: 13px;
                        font-weight: 600;
                        color: Theme.text-primary;
                    }
                    editor-input := InputArea {
                        text: root.editor-text;
                        placeholder: "输入常用语,可多行…";
                        vertical-stretch: 1;
                        // 浮层随 editor-open 创建,init 即自动聚焦、光标落文末
                        init => { self.focus-end(); }
                    }
                    HorizontalLayout {
                        alignment: end;
                        spacing: 8px;
                        GhostButton {
                            text: "取消";
                            clicked => { root.editor-open = false; }
                        }
                        PrimaryButton {
                            text: "保存";
                            clicked => {
                                root.editor-saved(editor-input.text);
                                root.editor-open = false;
                            }
                        }
                    }
                }
            }
        }

        // ---- 保存失败横幅(压底浮层;点击关闭) ----
        if root.save-error != "": Rectangle {
            x: 12px;
            y: root.height - 42px;
            width: root.width - 24px;
            height: 32px;
            border-radius: 8px;
            background: #fee2e2;
            border-width: 1px;
            border-color: Theme.danger;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                Text {
                    text: root.save-error;
                    color: Theme.danger;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
            TouchArea {
                mouse-cursor: pointer;
                clicked => { root.save-error = ""; }
            }
        }
    }
}
