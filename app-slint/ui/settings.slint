import { ListView, ScrollView } from "std-widgets.slint";
import {
    Theme, GroupRowUi, PhraseRowUi, PetCardUi, GroupIcon, IconButton,
    PrimaryButton, GhostButton, InputArea, SegmentedPair
} from "common.slint";

export component SettingsWindow inherits Window {
    in property <[GroupRowUi]> groups;
    in property <[PhraseRowUi]> phrases;
    in property <[PetCardUi]> pets;
    in property <string> group-name;
    in property <int> group-icon-idx;
    in property <bool> has-group;
    in property <bool> solid-theme;
    in-out property <bool> autostart-on;
    in property <string> custom-dir;
    in property <string> data-msg;

    // 确认框
    in-out property <bool> confirm-visible: false;
    in property <string> confirm-title;
    in property <string> confirm-msg;
    callback confirm-ok;

    callback group-selected(int);
    callback group-add;
    callback group-renamed(string);
    callback group-icon-set(int);
    callback group-delete;
    callback group-dropped(int, int); // from, to(拖拽落点)
    callback phrase-add(string);
    callback phrase-edited(int, string);
    callback phrase-delete(int);
    callback phrase-dropped(int, int);
    callback pet-selected(int);
    callback theme-toggled(bool); // true=solid
    callback autostart-toggled(bool);
    callback pick-dir;
    callback do-export;
    callback do-import;

    in-out property <int> editing-idx: -1;
    in-out property <int> page: 0;

    // 拖拽排序状态
    in-out property <int> drag-group: -1;
    in-out property <length> drag-group-dy: 0;
    in-out property <bool> drag-group-done: false;
    in-out property <int> drag-phrase: -1;
    in-out property <length> drag-phrase-dy: 0;

    title: "PetPhrase 设置";
    icon: @image-url("icon.png");
    default-font-family: "Microsoft YaHei UI";
    width: 780px;
    height: 560px;
    background: #f8fafc;
    default-font-size: 13px;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // ---- 顶部页签 ----
        Rectangle {
            height: 42px;
            background: #ffffff;
            HorizontalLayout {
                padding-left: 16px;
                padding-top: 6px;
                spacing: 4px;
                alignment: start;
                for label[i] in ["常用语", "外观与行为"]: Rectangle {
                    width: pt.preferred-width + 32px;
                    pt := Text {
                        text: label;
                        font-size: 13px;
                        font-weight: root.page == i ? 600 : 400;
                        color: root.page == i ? Theme.accent : Theme.text-muted;
                    }
                    Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        width: parent.width - 16px;
                        x: 8px;
                        background: root.page == i ? Theme.accent : transparent;
                    }
                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.page = i; }
                    }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: #e2e8f0; }
        }

        // ================= 常用语页 =================
        if root.page == 0: HorizontalLayout {
            padding: 0;
            spacing: 0;

            // 左栏分组(长按拖动排序)
            Rectangle {
                width: 200px;
                background: #ffffff;
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    ListView {
                        vertical-stretch: 1;
                        for g[i] in root.groups: Rectangle {
                            height: 40px;
                            grow := Rectangle {
                                y: root.drag-group == i ? root.drag-group-dy : 0;
                                height: 38px;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: g.selected ? #f9731650 : transparent;
                                background: root.drag-group == i ? #fff7ed
                                    : g.selected ? Theme.accent-soft
                                    : grow-ta.has-hover ? #f1f5f9 : transparent;
                                opacity: root.drag-group == i ? 0.92 : 1.0;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        alignment: center;
                                        GroupIcon {
                                            idx: g.icon-idx;
                                            tint: g.selected ? Theme.accent : Theme.text-muted;
                                        }
                                    }
                                    Text {
                                        text: g.name;
                                        color: g.selected ? Theme.text-primary : Theme.text-secondary;
                                        font-weight: g.selected ? 600 : 400;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: g.count;
                                        color: Theme.text-placeholder;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                                grow-ta := TouchArea {
                                    mouse-cursor: root.drag-group == i ? grabbing : pointer;
                                    moved => {
                                        if (self.pressed && (root.drag-group == i || Math.abs(self.mouse-y / 1px - self.pressed-y / 1px) > 8)) {
                                            root.drag-group = i;
                                            root.drag-group-dy = self.mouse-y - self.pressed-y;
                                        }
                                    }
                                    pointer-event(e) => {
                                        if (e.kind == PointerEventKind.up && root.drag-group == i) {
                                            root.group-dropped(i, i + Math.round((self.mouse-y - self.pressed-y) / 40px));
                                            root.drag-group = -1;
                                            root.drag-group-done = true;
                                        }
                                    }
                                    clicked => {
                                        if (root.drag-group-done) {
                                            root.drag-group-done = false;
                                        } else {
                                            root.group-selected(i);
                                        }
                                    }
                                }
                            }
                        }
                    }
                    GhostButton {
                        text: "+ 新建分组";
                        clicked => { root.group-add(); }
                    }
                }
                Rectangle { x: parent.width - 1px; width: 1px; background: #e2e8f0; }
            }

            // 右栏
            VerticalLayout {
                padding: 0;
                spacing: 0;
                horizontal-stretch: 1;

                // 分组头:大号内联改名 + 图标选择 + 幽灵删除
                Rectangle {
                    height: 92px;
                    background: #ffffff;
                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        spacing: 8px;
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                width: 240px;
                                height: 32px;
                                name-input := TextInput {
                                    text: root.group-name;
                                    enabled: root.has-group;
                                    font-size: 16px;
                                    font-weight: 600;
                                    color: Theme.text-primary;
                                    single-line: true;
                                    vertical-alignment: center;
                                    accepted => { root.group-renamed(self.text); self.clear-focus(); }
                                    changed has-focus => {
                                        if (!self.has-focus) { root.group-renamed(self.text); }
                                    }
                                }
                                // 底部下划线:悬停/聚焦时浮现,提示可改名
                                Rectangle {
                                    y: parent.height - 2px;
                                    height: 2px;
                                    width: Math.min(parent.width, name-input.preferred-width + 12px);
                                    background: name-input.has-focus ? Theme.accent
                                        : name-ta.has-hover ? #e2e8f0 : transparent;
                                }
                                name-ta := TouchArea {
                                    visible: !name-input.has-focus;
                                    mouse-cursor: text;
                                    clicked => { name-input.focus(); }
                                }
                                if name-ta.has-hover && !name-input.has-focus: Image {
                                    source: @image-url("icons/pencil.svg");
                                    colorize: Theme.text-placeholder;
                                    width: 13px;
                                    height: 13px;
                                    x: Math.min(parent.width - 16px, name-input.preferred-width + 8px);
                                    y: (parent.height - 13px) / 2;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            if root.has-group: GhostButton {
                                text: "删除分组";
                                danger: true;
                                icon: @image-url("icons/trash-2.svg");
                                clicked => { root.group-delete(); }
                            }
                        }
                        HorizontalLayout {
                            spacing: 2px;
                            alignment: start;
                            for icon-i in 12: Rectangle {
                                width: 26px;
                                height: 26px;
                                border-radius: 6px;
                                background: root.group-icon-idx == icon-i ? Theme.accent-soft : (ic-ta.has-hover ? #f1f5f9 : transparent);
                                VerticalLayout {
                                    alignment: center;
                                    HorizontalLayout {
                                        alignment: center;
                                        GroupIcon {
                                            idx: icon-i;
                                            width: 14px;
                                            height: 14px;
                                            tint: root.group-icon-idx == icon-i ? Theme.accent : Theme.text-muted;
                                        }
                                    }
                                }
                                ic-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.group-icon-set(icon-i); }
                                }
                            }
                        }
                    }
                    Rectangle { y: parent.height - 1px; height: 1px; background: #e2e8f0; }
                }

                // 短语列表(长按拖动排序)
                ListView {
                    vertical-stretch: 1;
                    for p[i] in root.phrases: Rectangle {
                        property <bool> editing: root.editing-idx == i;
                        height: editing ? 132px : 52px;
                        prow := Rectangle {
                            x: 16px;
                            width: parent.width - 32px;
                            y: (root.drag-phrase == i ? root.drag-phrase-dy : 0) + 4px;
                            height: parent.height - 8px;
                            border-radius: 8px;
                            // 拖拽视觉走轻量路线(边框+底色),软渲染下阴影重算是卡顿源
                            border-width: root.drag-phrase == i ? 2px : 1px;
                            border-color: editing || root.drag-phrase == i ? Theme.accent : #e2e8f0;
                            background: root.drag-phrase == i ? #fff7ed : #ffffff;
                            opacity: root.drag-phrase == i ? 0.92 : 1.0;

                            if !editing: HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 8px;
                                spacing: 6px;
                                Text {
                                    text: p.text;
                                    color: Theme.text-primary;
                                    font-size: 12.5px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                // 拖动手柄:按住直接拖
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 24px;
                                        height: 24px;
                                        border-radius: 6px;
                                        background: grip-ta.has-hover || root.drag-phrase == i ? #f1f5f9 : transparent;
                                        Image {
                                            source: @image-url("icons/grip-vertical.svg");
                                            colorize: Theme.text-placeholder;
                                            width: 14px;
                                            height: 14px;
                                        }
                                        grip-ta := TouchArea {
                                            mouse-cursor: root.drag-phrase == i ? grabbing : grab;
                                            moved => {
                                                if (self.pressed) {
                                                    root.drag-phrase = i;
                                                    root.drag-phrase-dy = self.mouse-y - self.pressed-y;
                                                }
                                            }
                                            pointer-event(e) => {
                                                if (e.kind == PointerEventKind.up && root.drag-phrase == i) {
                                                    root.phrase-dropped(i, i + Math.round((self.mouse-y - self.pressed-y) / 52px));
                                                    root.drag-phrase = -1;
                                                }
                                            }
                                        }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    IconButton {
                                        icon: @image-url("icons/pencil.svg");
                                        clicked => { root.editing-idx = i; }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    IconButton {
                                        icon: @image-url("icons/trash-2.svg");
                                        tint: Theme.danger;
                                        clicked => { root.phrase-delete(i); }
                                    }
                                }
                            }

                            if editing: VerticalLayout {
                                padding: 8px;
                                spacing: 6px;
                                edit-area := InputArea {
                                    text: p.text;
                                    vertical-stretch: 1;
                                }
                                HorizontalLayout {
                                    alignment: end;
                                    spacing: 6px;
                                    GhostButton { text: "取消"; clicked => { root.editing-idx = -1; } }
                                    PrimaryButton {
                                        text: "保存";
                                        clicked => {
                                            root.phrase-edited(i, edit-area.text);
                                            root.editing-idx = -1;
                                        }
                                    }
                                }
                            }

                            if !editing: TouchArea {
                                // 行体长按拖拽(与手柄二选一均可);右侧 116px 留给手柄/编辑/删除
                                width: Math.max(0px, parent.width - 116px);
                                moved => {
                                    if (self.pressed && (root.drag-phrase == i || Math.abs(self.mouse-y / 1px - self.pressed-y / 1px) > 10)) {
                                        root.drag-phrase = i;
                                        root.drag-phrase-dy = self.mouse-y - self.pressed-y;
                                    }
                                }
                                pointer-event(e) => {
                                    if (e.kind == PointerEventKind.up && root.drag-phrase == i) {
                                        root.phrase-dropped(i, i + Math.round((self.mouse-y - self.pressed-y) / 52px));
                                        root.drag-phrase = -1;
                                    }
                                }
                            }
                        }
                    }
                }

                // 添加区
                Rectangle {
                    height: 96px;
                    background: #ffffff;
                    Rectangle { height: 1px; background: #e2e8f0; }
                    HorizontalLayout {
                        padding: 14px;
                        spacing: 10px;
                        new-phrase := InputArea {
                            horizontal-stretch: 1;
                            placeholder: "输入新常用语,可多行…";
                        }
                        VerticalLayout {
                            alignment: end;
                            PrimaryButton {
                                text: "添加";
                                enabled: root.has-group;
                                clicked => {
                                    root.phrase-add(new-phrase.text);
                                    new-phrase.text = "";
                                }
                            }
                        }
                    }
                }
            }
        }

        // ================= 外观与行为页 =================
        if root.page == 1: ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 24px;
                spacing: 10px;
                alignment: start;

                Text { text: "桌宠形象"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                Text {
                    text: "扫描内置宠物、~/.codex/pets(npx petdex 安装位置)与自定义目录,兼容 petdex 格式。";
                    font-size: 12px;
                    color: Theme.text-muted;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    for pet[i] in root.pets: Rectangle {
                        width: 118px;
                        height: 132px;
                        border-radius: 12px;
                        border-width: 2px;
                        border-color: pet.selected ? Theme.accent : (pet-ta.has-hover && pet.err == "" ? #cbd5e1 : #e2e8f0);
                        background: pet.selected ? #fff7ed : #ffffff;
                        opacity: pet.err != "" ? 0.55 : 1.0;
                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            alignment: center;
                            if pet.err == "": Image {
                                source: pet.thumb;
                                width: 72px;
                                height: 78px;
                                image-fit: contain;
                                source-clip-x: 0;
                                source-clip-y: 0;
                                source-clip-width: 192;
                                source-clip-height: 208;
                            }
                            Text {
                                text: pet.name;
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                color: Theme.text-primary;
                                overflow: elide;
                            }
                            if pet.err != "": Text {
                                text: pet.err;
                                font-size: 10.5px;
                                color: Theme.danger;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                        pet-ta := TouchArea {
                            enabled: pet.err == "";
                            mouse-cursor: pointer;
                            clicked => { root.pet-selected(i); }
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    GhostButton { text: "选择自定义宠物目录…"; clicked => { root.pick-dir(); } }
                    Text { text: root.custom-dir; font-size: 12px; color: Theme.text-muted; vertical-alignment: center; }
                }

                Rectangle { height: 8px; }
                Text { text: "面板主题"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                SegmentedPair {
                    left-label: "亚克力磨砂";
                    right-label: "实底浅色";
                    right-selected: root.solid-theme;
                    changed(solid) => { root.theme-toggled(solid); }
                }

                Rectangle { height: 8px; }
                Text { text: "行为"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                HorizontalLayout {
                    alignment: start;
                    spacing: 8px;
                    Rectangle {
                        width: 38px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.autostart-on ? Theme.accent : #cbd5e1;
                        animate background { duration: 150ms; }
                        Rectangle {
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: #ffffff;
                            x: root.autostart-on ? parent.width - self.width - 2px : 2px;
                            y: 2px;
                            animate x { duration: 150ms; easing: ease-out; }
                        }
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.autostart-on = !root.autostart-on;
                                root.autostart-toggled(root.autostart-on);
                            }
                        }
                    }
                    Text { text: "开机自动启动"; vertical-alignment: center; color: Theme.text-secondary; }
                }

                Rectangle { height: 8px; }
                Text { text: "数据"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    GhostButton { text: "导出常用语…"; icon: @image-url("icons/download.svg"); clicked => { root.do-export(); } }
                    GhostButton { text: "导入常用语…"; icon: @image-url("icons/upload.svg"); clicked => { root.do-import(); } }
                    Text { text: root.data-msg; font-size: 12px; color: Theme.text-muted; vertical-alignment: center; }
                }
            }
        }
    }

    // ---- 应用内确认框 ----
    if root.confirm-visible: Rectangle {
        background: #0f172a73;
        TouchArea { clicked => { root.confirm-visible = false; } }
        Rectangle {
            width: 320px;
            height: 190px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #ffffff;
            border-radius: 14px;
            drop-shadow-blur: 40px;
            drop-shadow-color: #0f172a47;
            TouchArea { } // 挡穿透
            VerticalLayout {
                padding: 20px;
                spacing: 8px;
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 44px;
                        height: 44px;
                        border-radius: 22px;
                        background: #fef2f2;
                        Image {
                            source: @image-url("icons/trash-2.svg");
                            colorize: Theme.danger;
                            width: 20px;
                            height: 20px;
                        }
                    }
                }
                Text {
                    text: root.confirm-title;
                    font-size: 15px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    color: Theme.text-primary;
                }
                Text {
                    text: root.confirm-msg;
                    font-size: 12.5px;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    GhostButton {
                        text: "取消";
                        clicked => { root.confirm-visible = false; }
                    }
                    Rectangle {
                        width: 96px;
                        height: 34px;
                        border-radius: 8px;
                        background: del-ta.has-hover ? #b91c1c : Theme.danger;
                        animate background { duration: 150ms; }
                        Text { text: "删除"; color: #ffffff; font-weight: 600; }
                        del-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.confirm-visible = false;
                                root.confirm-ok();
                            }
                        }
                    }
                }
            }
        }
    }
}
