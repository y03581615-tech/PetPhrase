import { ListView, ScrollView } from "std-widgets.slint";
import {
    Theme, GroupRowUi, PhraseRowUi, PetCardUi, GroupIcon, IconButton,
    PrimaryButton, GhostButton, InputArea, SegmentedPair, SegmentedRow, ToggleSwitch
} from "common.slint";

export component SettingsWindow inherits Window {
    in property <[GroupRowUi]> groups;
    in property <[PhraseRowUi]> phrases;
    in property <[PetCardUi]> pets;
    in property <string> group-name;
    in property <int> group-icon-idx;
    in property <bool> has-group;
    in property <bool> solid-theme;
    in property <int> pet-size-idx: 2; // 0小 1中 2大
    in-out property <bool> autostart-on;
    in property <string> custom-dir;
    in property <string> data-msg;

    // 关于与更新
    in property <string> app-version;
    in property <string> update-msg;
    in property <bool> update-available;
    in property <bool> update-busy;
    in-out property <bool> auto-check-on;
    callback check-update;
    callback do-update;
    callback auto-check-toggled(bool);

    // 确认框
    in-out property <bool> confirm-visible: false;
    in property <string> confirm-title;
    in property <string> confirm-msg;
    callback confirm-ok;

    callback group-selected(int);
    callback group-add;
    callback group-renamed(string);
    callback group-icon-set(int);
    callback group-delete;
    callback group-dropped(int, int); // from, to(拖拽落点)
    callback phrase-add(string);
    callback phrase-edited(int, string);
    callback phrase-delete(int);
    callback phrase-dropped(int, int);
    callback pet-selected(int);
    callback theme-toggled(bool); // true=solid
    callback pet-size-changed(int);
    callback autostart-toggled(bool);
    callback pick-dir;
    callback do-export;
    callback do-import;

    in-out property <int> editing-idx: -1;
    in-out property <int> page: 0;
    // 分组名编辑态;切换/新建/删除分组时由 Rust refresh_settings 强制复位
    in-out property <bool> renaming: false;

    // 拖拽排序状态
    in-out property <int> drag-group: -1;
    in-out property <length> drag-group-dy: 0;
    in-out property <bool> drag-group-done: false;
    in-out property <int> drag-phrase: -1;
    in-out property <length> drag-phrase-dy: 0;

    title: "PetPhrase 设置";
    icon: @image-url("icon.png");
    default-font-family: "Microsoft YaHei UI";
    width: 780px;
    height: 560px;
    background: #f8fafc;
    default-font-size: 13px;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // ---- 顶部页签 ----
        Rectangle {
            height: 42px;
            background: #ffffff;
            HorizontalLayout {
                padding-left: 16px;
                padding-top: 6px;
                spacing: 4px;
                alignment: start;
                for label[i] in ["常用语", "外观与行为"]: Rectangle {
                    width: pt.preferred-width + 32px;
                    pt := Text {
                        text: label;
                        font-size: 13px;
                        font-weight: root.page == i ? 600 : 400;
                        color: root.page == i ? Theme.accent : Theme.text-muted;
                    }
                    Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        width: parent.width - 16px;
                        x: 8px;
                        background: root.page == i ? Theme.accent : transparent;
                    }
                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.page = i; }
                    }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: #e2e8f0; }
        }

        // ================= 常用语页 =================
        if root.page == 0: HorizontalLayout {
            padding: 0;
            spacing: 0;

            // 左栏分组(长按拖动排序)
            Rectangle {
                width: 200px;
                background: #ffffff;
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    Rectangle {
                        vertical-stretch: 1;
                        glist := ListView {
                        width: 100%;
                        height: 100%;
                        for g[i] in root.groups: Rectangle {
                            height: 40px;
                            grow := Rectangle {
                                height: 38px;
                                border-radius: 8px;
                                border-width: root.drag-group == i ? 2px : 1px;
                                border-color: root.drag-group == i ? Theme.accent
                                    : g.selected ? #f9731650 : transparent;
                                background: root.drag-group == i ? #fff7ed
                                    : g.selected ? Theme.accent-soft
                                    : grow-ta.has-hover ? #f1f5f9 : transparent;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    VerticalLayout {
                                        alignment: center;
                                        GroupIcon {
                                            idx: g.icon-idx;
                                            tint: g.selected ? Theme.accent : Theme.text-muted;
                                        }
                                    }
                                    Text {
                                        text: g.name;
                                        color: g.selected ? Theme.text-primary : Theme.text-secondary;
                                        font-weight: g.selected ? 600 : 400;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                    Text {
                                        text: g.count;
                                        color: Theme.text-placeholder;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                                grow-ta := TouchArea {
                                    mouse-cursor: root.drag-group == i ? grabbing : pointer;
                                    moved => {
                                        if (self.pressed && (root.drag-group == i || Math.abs(self.mouse-y / 1px - self.pressed-y / 1px) > 8)) {
                                            root.drag-group = i;
                                            root.drag-group-dy = self.mouse-y - self.pressed-y;
                                        }
                                    }
                                    pointer-event(e) => {
                                        if (e.kind == PointerEventKind.up && root.drag-group == i) {
                                            root.group-dropped(i, i + Math.round((self.mouse-y - self.pressed-y) / 40px));
                                            root.drag-group = -1;
                                            root.drag-group-done = true;
                                        }
                                    }
                                    clicked => {
                                        if (root.drag-group-done) {
                                            root.drag-group-done = false;
                                        } else {
                                            root.group-selected(i);
                                        }
                                    }
                                }
                            }
                        }
                        }
                        // 拖拽插入指示线(只重绘这一条线,零卡顿)
                        if root.drag-group >= 0: Rectangle {
                            x: 2px;
                            width: parent.width - 4px;
                            height: 3px;
                            border-radius: 1.5px;
                            background: Theme.accent;
                            y: Math.clamp(
                                (Math.clamp(root.drag-group + Math.round(root.drag-group-dy / 40px) + (root.drag-group-dy > 0 ? 1 : 0), 0, root.groups.length) * 40px) + glist.viewport-y,
                                0px, parent.height - 3px);
                        }
                    }
                    GhostButton {
                        text: "+ 新建分组";
                        clicked => { root.group-add(); }
                    }
                }
                Rectangle { x: parent.width - 1px; width: 1px; background: #e2e8f0; }
            }

            // 右栏
            VerticalLayout {
                padding: 0;
                spacing: 0;
                horizontal-stretch: 1;

                // 分组头:大号内联改名 + 图标选择 + 幽灵删除
                Rectangle {
                    height: 92px;
                    background: #ffffff;
                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        spacing: 8px;
                        HorizontalLayout {
                            spacing: 8px;
                            // 分组名两态:显示态(Text 绑定,悬停出铅笔)/ 编辑态(TextInput + 下划线)。
                            // 不能让 TextInput 常驻绑定 group-name:用户一打字绑定即被拆,之后永不跟随
                            Rectangle {
                                width: 240px;
                                height: 32px;

                                // ---- 显示态 ----
                                HorizontalLayout {
                                    visible: !root.renaming;
                                    spacing: 6px;
                                    alignment: start;
                                    Text {
                                        text: root.group-name;
                                        font-size: 16px;
                                        font-weight: 600;
                                        color: Theme.text-primary;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        Image {
                                            source: @image-url("icons/pencil.svg");
                                            colorize: name-ta.has-hover ? Theme.text-secondary : Theme.text-placeholder;
                                            width: 13px;
                                            height: 13px;
                                            // 常显淡色铅笔作可改名提示,悬停加深
                                            opacity: !root.has-group ? 0 : (name-ta.has-hover ? 1 : 0.55);
                                            animate opacity { duration: 150ms; }
                                        }
                                    }
                                }
                                name-ta := TouchArea {
                                    visible: !root.renaming;
                                    enabled: root.has-group;
                                    mouse-cursor: text;
                                    clicked => {
                                        rename-input.text = root.group-name;
                                        root.renaming = true;
                                        rename-input.focus();
                                        // 全选:直接打字即整体替换,免去手动移光标删旧名
                                        rename-input.select-all();
                                    }
                                }

                                // ---- 编辑态 ----
                                rename-input := TextInput {
                                    visible: root.renaming;
                                    enabled: root.renaming;
                                    font-size: 16px;
                                    font-weight: 600;
                                    color: Theme.text-primary;
                                    single-line: true;
                                    vertical-alignment: center;
                                    accepted => {
                                        if (root.renaming) {
                                            root.renaming = false;
                                            root.group-renamed(self.text);
                                        }
                                        self.clear-focus();
                                    }
                                    key-pressed(event) => {
                                        if (event.text == Key.Escape) {
                                            root.renaming = false; // 先退编辑态,失焦提交才会跳过
                                            self.clear-focus();
                                            return accept;
                                        }
                                        reject
                                    }
                                    changed has-focus => {
                                        if (root.renaming && !self.has-focus) {
                                            root.renaming = false;
                                            root.group-renamed(self.text);
                                        }
                                    }
                                }
                                Rectangle {
                                    visible: root.renaming;
                                    y: parent.height - 2px;
                                    height: 2px;
                                    background: Theme.accent;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            if root.has-group: GhostButton {
                                text: "删除分组";
                                danger: true;
                                icon: @image-url("icons/trash-2.svg");
                                clicked => { root.group-delete(); }
                            }
                        }
                        HorizontalLayout {
                            spacing: 2px;
                            alignment: start;
                            for icon-i in 12: Rectangle {
                                width: 26px;
                                height: 26px;
                                border-radius: 6px;
                                background: root.group-icon-idx == icon-i ? Theme.accent-soft : (ic-ta.has-hover ? #f1f5f9 : transparent);
                                VerticalLayout {
                                    alignment: center;
                                    HorizontalLayout {
                                        alignment: center;
                                        GroupIcon {
                                            idx: icon-i;
                                            width: 14px;
                                            height: 14px;
                                            tint: root.group-icon-idx == icon-i ? Theme.accent : Theme.text-muted;
                                        }
                                    }
                                }
                                ic-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.group-icon-set(icon-i); }
                                }
                            }
                        }
                    }
                    Rectangle { y: parent.height - 1px; height: 1px; background: #e2e8f0; }
                }

                // 短语列表(拖动手柄/长按行体排序,插入线指示落点)
                Rectangle {
                    vertical-stretch: 1;
                    plist := ListView {
                    width: 100%;
                    height: 100%;
                    for p[i] in root.phrases: Rectangle {
                        property <bool> editing: root.editing-idx == i;
                        height: editing ? 132px : 52px;
                        prow := Rectangle {
                            x: 16px;
                            width: parent.width - 32px;
                            y: 4px;
                            height: parent.height - 8px;
                            border-radius: 8px;
                            border-width: root.drag-phrase == i ? 2px : 1px;
                            border-color: editing || root.drag-phrase == i ? Theme.accent : #e2e8f0;
                            background: root.drag-phrase == i ? #fff7ed : #ffffff;
                            clip: true;

                            if !editing: HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 8px;
                                spacing: 6px;
                                Text {
                                    text: p.display;
                                    color: Theme.text-primary;
                                    font-size: 12.5px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                // 拖动手柄:按住直接拖
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 24px;
                                        height: 24px;
                                        border-radius: 6px;
                                        background: grip-ta.has-hover || root.drag-phrase == i ? #f1f5f9 : transparent;
                                        Image {
                                            source: @image-url("icons/grip-vertical.svg");
                                            colorize: Theme.text-placeholder;
                                            width: 14px;
                                            height: 14px;
                                        }
                                        grip-ta := TouchArea {
                                            mouse-cursor: root.drag-phrase == i ? grabbing : grab;
                                            moved => {
                                                if (self.pressed) {
                                                    root.drag-phrase = i;
                                                    root.drag-phrase-dy = self.mouse-y - self.pressed-y;
                                                }
                                            }
                                            pointer-event(e) => {
                                                if (e.kind == PointerEventKind.up && root.drag-phrase == i) {
                                                    root.phrase-dropped(i, i + Math.round((self.mouse-y - self.pressed-y) / 52px));
                                                    root.drag-phrase = -1;
                                                }
                                            }
                                        }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    IconButton {
                                        icon: @image-url("icons/pencil.svg");
                                        clicked => { root.editing-idx = i; }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    IconButton {
                                        icon: @image-url("icons/trash-2.svg");
                                        tint: Theme.danger;
                                        clicked => { root.phrase-delete(i); }
                                    }
                                }
                            }

                            if editing: VerticalLayout {
                                padding: 8px;
                                spacing: 6px;
                                edit-area := InputArea {
                                    text: p.text;
                                    vertical-stretch: 1;
                                }
                                HorizontalLayout {
                                    alignment: end;
                                    spacing: 6px;
                                    GhostButton { text: "取消"; clicked => { root.editing-idx = -1; } }
                                    PrimaryButton {
                                        text: "保存";
                                        clicked => {
                                            root.phrase-edited(i, edit-area.text);
                                            root.editing-idx = -1;
                                        }
                                    }
                                }
                            }

                            if !editing: TouchArea {
                                // 行体长按拖拽(与手柄二选一均可);右侧 116px 留给手柄/编辑/删除
                                width: Math.max(0px, parent.width - 116px);
                                moved => {
                                    if (self.pressed && (root.drag-phrase == i || Math.abs(self.mouse-y / 1px - self.pressed-y / 1px) > 10)) {
                                        root.drag-phrase = i;
                                        root.drag-phrase-dy = self.mouse-y - self.pressed-y;
                                    }
                                }
                                pointer-event(e) => {
                                    if (e.kind == PointerEventKind.up && root.drag-phrase == i) {
                                        root.phrase-dropped(i, i + Math.round((self.mouse-y - self.pressed-y) / 52px));
                                        root.drag-phrase = -1;
                                    }
                                }
                            }
                        }
                    }
                    }
                    // 拖拽插入指示线
                    if root.drag-phrase >= 0: Rectangle {
                        x: 16px;
                        width: parent.width - 32px;
                        height: 3px;
                        border-radius: 1.5px;
                        background: Theme.accent;
                        y: Math.clamp(
                            (Math.clamp(root.drag-phrase + Math.round(root.drag-phrase-dy / 52px) + (root.drag-phrase-dy > 0 ? 1 : 0), 0, root.phrases.length) * 52px) + plist.viewport-y,
                            0px, parent.height - 3px);
                    }
                    // 跟手幽灵条:拖到哪条随到哪(单个小元素,零卡顿)
                    if root.drag-phrase >= 0: Rectangle {
                        x: 24px;
                        width: parent.width - 48px;
                        height: 40px;
                        border-radius: 8px;
                        background: #fff7ed;
                        border-width: 1.5px;
                        border-color: Theme.accent;
                        clip: true;
                        y: Math.clamp(
                            root.drag-phrase * 52px + root.drag-phrase-dy + plist.viewport-y + 6px,
                            0px, parent.height - 40px);
                        Text {
                            x: 12px;
                            width: parent.width - 24px;
                            height: 100%;
                            text: root.phrases[root.drag-phrase].display;
                            color: Theme.text-primary;
                            font-size: 12.5px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                // 添加区
                Rectangle {
                    height: 96px;
                    background: #ffffff;
                    Rectangle { height: 1px; background: #e2e8f0; }
                    HorizontalLayout {
                        padding: 14px;
                        spacing: 10px;
                        new-phrase := InputArea {
                            horizontal-stretch: 1;
                            placeholder: "输入新常用语,可多行…";
                        }
                        VerticalLayout {
                            alignment: center; // 与输入框垂直居中对齐
                            PrimaryButton {
                                text: "添加";
                                enabled: root.has-group;
                                clicked => {
                                    root.phrase-add(new-phrase.text);
                                    new-phrase.text = "";
                                }
                            }
                        }
                    }
                }
            }
        }

        // ================= 外观与行为页 =================
        if root.page == 1: ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 24px;
                spacing: 10px;
                alignment: start;

                Text { text: "桌宠形象"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                Text {
                    text: "扫描内置宠物、~/.codex/pets(npx petdex 安装位置)与自定义目录,兼容 petdex 格式。鼠标悬停列表,滚轮可横向浏览全部桌宠。";
                    font-size: 12px;
                    color: Theme.text-muted;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 140px;
                    pet-scroll := ScrollView {
                        height: 132px;
                        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
                        mouse-drag-pan-enabled: true;

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: start;
                            for pet[i] in root.pets: Rectangle {
                                width: 118px;
                                height: 132px;
                                border-radius: 12px;
                                border-width: 2px;
                                border-color: pet.selected ? Theme.accent : (pet-ta.has-hover && pet.err == "" ? #cbd5e1 : #e2e8f0);
                                background: pet.selected ? #fff7ed : #ffffff;
                                opacity: pet.err != "" ? 0.55 : 1.0;
                                VerticalLayout {
                                    padding: 8px;
                                    spacing: 4px;
                                    alignment: center;
                                    // thumb 已是 Rust 侧预裁好的单帧,无需 source-clip
                                    if pet.err == "": Image {
                                        source: pet.thumb;
                                        width: 72px;
                                        height: 78px;
                                        image-fit: contain;
                                    }
                                    Text {
                                        text: pet.name;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        color: Theme.text-primary;
                                        overflow: elide;
                                    }
                                    if pet.err != "": Text {
                                        text: pet.err;
                                        font-size: 10.5px;
                                        color: Theme.danger;
                                        horizontal-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                                pet-ta := TouchArea {
                                    enabled: pet.err == "";
                                    mouse-cursor: pointer;
                                    clicked => { root.pet-selected(i); }
                                    scroll-event(event) => {
                                        pet-scroll.viewport-x = Math.max(0px, Math.min(
                                            pet-scroll.viewport-x - event.delta-y,
                                            pet-scroll.viewport-width - pet-scroll.width));
                                        accept;
                                    }
                                }
                            }
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    GhostButton { text: "选择自定义宠物目录…"; clicked => { root.pick-dir(); } }
                    Text { text: root.custom-dir; font-size: 12px; color: Theme.text-muted; vertical-alignment: center; }
                }

                Rectangle { height: 8px; }
                Text { text: "桌宠大小"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                SegmentedRow {
                    labels: ["小", "中", "大"];
                    selected: root.pet-size-idx;
                    changed(i) => { root.pet-size-changed(i); }
                }

                Rectangle { height: 8px; }
                Text { text: "面板主题"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                SegmentedPair {
                    left-label: "亚克力磨砂";
                    right-label: "实底浅色";
                    right-selected: root.solid-theme;
                    changed(solid) => { root.theme-toggled(solid); }
                }

                Rectangle { height: 8px; }
                Text { text: "行为"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                HorizontalLayout {
                    alignment: start;
                    spacing: 8px;
                    ToggleSwitch {
                        on: root.autostart-on;
                        toggled(v) => {
                            root.autostart-on = v;
                            root.autostart-toggled(v);
                        }
                    }
                    Text { text: "开机自动启动"; vertical-alignment: center; color: Theme.text-secondary; }
                }

                Rectangle { height: 8px; }
                Text { text: "数据"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    GhostButton { text: "导出常用语…"; icon: @image-url("icons/download.svg"); clicked => { root.do-export(); } }
                    GhostButton { text: "导入常用语…"; icon: @image-url("icons/upload.svg"); clicked => { root.do-import(); } }
                    Text { text: root.data-msg; font-size: 12px; color: Theme.text-muted; vertical-alignment: center; }
                }

                Rectangle { height: 8px; }
                Text { text: "关于与更新"; font-size: 14px; font-weight: 600; color: Theme.text-primary; }
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;
                    Text {
                        text: "当前版本 v" + root.app-version;
                        font-size: 12.5px;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }
                    if !root.update-available: GhostButton {
                        text: "检查更新";
                        enabled: !root.update-busy;
                        clicked => { root.check-update(); }
                    }
                    if root.update-available: PrimaryButton {
                        text: "立即更新";
                        enabled: !root.update-busy;
                        clicked => { root.do-update(); }
                    }
                    Text { text: root.update-msg; font-size: 12px; color: Theme.text-muted; vertical-alignment: center; }
                }
                HorizontalLayout {
                    alignment: start;
                    spacing: 8px;
                    ToggleSwitch {
                        on: root.auto-check-on;
                        toggled(v) => {
                            root.auto-check-on = v;
                            root.auto-check-toggled(v);
                        }
                    }
                    Text { text: "启动时自动检查更新"; vertical-alignment: center; color: Theme.text-secondary; }
                }
            }
        }
    }

    // ---- 应用内确认框 ----
    if root.confirm-visible: Rectangle {
        background: #0f172a73;
        TouchArea { clicked => { root.confirm-visible = false; } }
        Rectangle {
            width: 320px;
            height: 190px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #ffffff;
            border-radius: 14px;
            drop-shadow-blur: 40px;
            drop-shadow-color: #0f172a47;
            TouchArea { } // 挡穿透
            VerticalLayout {
                padding: 20px;
                spacing: 8px;
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 44px;
                        height: 44px;
                        border-radius: 22px;
                        background: #fef2f2;
                        Image {
                            source: @image-url("icons/trash-2.svg");
                            colorize: Theme.danger;
                            width: 20px;
                            height: 20px;
                        }
                    }
                }
                Text {
                    text: root.confirm-title;
                    font-size: 15px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    color: Theme.text-primary;
                }
                Text {
                    text: root.confirm-msg;
                    font-size: 12.5px;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    GhostButton {
                        text: "取消";
                        clicked => { root.confirm-visible = false; }
                    }
                    Rectangle {
                        width: 96px;
                        height: 34px;
                        border-radius: 8px;
                        background: del-ta.has-hover ? #b91c1c : Theme.danger;
                        animate background { duration: 150ms; }
                        Text { text: "删除"; color: #ffffff; font-weight: 600; }
                        del-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.confirm-visible = false;
                                root.confirm-ok();
                            }
                        }
                    }
                }
            }
        }
    }
}
